{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/shop", "destination": "/shop.html" },
    { "source": "/order", "destination": "/order.html" },
    { "source": "/workshops", "destination": "/workshops.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
